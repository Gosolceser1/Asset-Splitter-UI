# ------------------------------------------------------------------------------
# EditorConfig: shared editor/IDE style and formatting for this repo.
# Supported by VS Code, Visual Studio, Rider, and others. See: https://editorconfig.org
# These settings keep encoding, line endings, indentation, and whitespace consistent
# so everyone gets the same behavior without manual setup.
# ------------------------------------------------------------------------------

root = true

# Defaults for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C#, project, XAML, JSON: keep 4-space indent (redundant here but explicit)
[*.{cs,csproj,axaml,xaml,json}]
indent_size = 4

[*.cs]
# Microsoft-style readability preferences. Kept at suggestion level so the existing
# codebase can be refactored incrementally without failing builds.
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion
dotnet_style_qualification_for_event = false:suggestion
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_require_accessibility_modifiers = for_non_interface_members:suggestion

csharp_prefer_braces = true:suggestion
csharp_style_namespace_declarations = file_scoped:suggestion
csharp_style_prefer_method_group_conversion = true:suggestion
csharp_style_prefer_null_check_over_type_check = true:suggestion
csharp_style_prefer_primary_constructors = false:suggestion
csharp_style_var_elsewhere = false:suggestion
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion

dotnet_naming_rule.interface_should_start_with_i.severity = suggestion
dotnet_naming_rule.interface_should_start_with_i.symbols = interface
dotnet_naming_rule.interface_should_start_with_i.style = prefix_interface_with_i

dotnet_naming_rule.types_should_be_pascal_case.severity = suggestion
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum, delegate

dotnet_naming_style.prefix_interface_with_i.required_prefix = I
dotnet_naming_style.prefix_interface_with_i.capitalization = pascal_case
dotnet_naming_style.pascal_case.capitalization = pascal_case

# Markdown: do not trim trailing spaces (needed for line breaks in .md)
[*.md]
trim_trailing_whitespace = false

# YAML: common convention is 2-space indent
[*.{yml,yaml}]
indent_size = 2

# PowerShell scripts
[*.ps1]
indent_size = 4
