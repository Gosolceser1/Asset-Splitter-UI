<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <!--
      Redirect the NuGet global packages folder to a user-temp location.

      WHY: Windsurf (and other IDEs using Roslyn/Avalonia analyzers) holds read
      locks on DLLs inside the default global cache (~/.nuget/packages) for the
      lifetime of the language server. When that cache is empty or cleared,
      dotnet restore tries to re-extract those DLLs and fails with:
        "Access to the path 'Avalonia.Generators.dll' is denied."

      This nuget.config is picked up by ALL dotnet commands run in this repo
      (including the IDE's own background restore), so every NuGet operation
      uses the temp folder that the IDE is NOT watching, eliminating the lock.

      The folder is shared across runs to avoid re-downloading packages every time.
    -->
    <add key="globalPackagesFolder" value="%TEMP%\NuGetBuild" />
  </config>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
